type Action from BodyElement
  elements [
    fix variables [Variable] ]
  factory Action
    parameters [
      par variables [Variable] []
      par body [BodyElement] [] ]
    body [
      fix variables [Variable] _variables
      fix body [BodyElement] _body
      fix name String "ctx"
      fix valueType String org.evrete.api.RhsContext -> Unit ]
domain draco Draco
rule
  pattern
  action
actor
  start
  message
  signal