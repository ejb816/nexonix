type RuleAspect
  elements
    fix pattern Pattern
    fix values [Value]
    fix action Action
  factory
    parameters
      par pattern Pattern Pattern.Null
      par values [Value] []
      par action Action Action.Null
  globals
    fix isEmpty (RuleAspect => Boolean) ra => ra.values.isEmpty && ra.pattern.variables.isEmpty && ra.pattern.conditions.isEmpty && ra.action.body.isEmpty
domain draco Draco
