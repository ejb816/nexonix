{
  "typeName": {
    "name": "Primes",
    "namePackage": [
      "draco",
      "primes"
    ]
  },
  "dracoAspect": {
    "elements": [
      {
        "kind": "Fixed",
        "name": "knowledge",
        "valueType": "org.evrete.api.Knowledge",
        "value": "Rule.knowledgeService.newKnowledge(\"Primes\")"
      }
    ],
    "globalElements": [
      {
        "kind": "Dynamic",
        "name": "filter",
        "valueType": "LazyList[Int]",
        "parameters": [
          {
            "kind": "Parameter",
            "name": "naturals",
            "valueType": "LazyList[Int]"
          }
        ],
        "body": [
          {
            "kind": "Local",
            "name": "p",
            "valueType": "Int",
            "value": "naturals.head"
          }
        ],
        "value": "p #:: filter(naturals.tail.filter(_ % p != 0))"
      },
      {
        "kind": "Dynamic",
        "name": "naturals",
        "valueType": "LazyList[Int]",
        "parameters": [
          {
            "kind": "Parameter",
            "name": "start",
            "valueType": "Int",
            "value": "0"
          },
          {
            "kind": "Parameter",
            "name": "step",
            "valueType": "Int",
            "value": "1"
          }
        ],
        "value": "LazyList.from(start, step)"
      },
      {
        "kind": "Dynamic",
        "name": "composites",
        "valueType": "Seq[Int]",
        "parameters": [
          {
            "kind": "Parameter",
            "name": "primes",
            "valueType": "Seq[Int]"
          }
        ],
        "value": "naturals(2).filterNot(primes.contains(_)).take(primes.last - 1)"
      },
      {
        "kind": "Dynamic",
        "name": "primesFromComposites",
        "valueType": "Seq[Int]",
        "parameters": [
          {
            "kind": "Parameter",
            "name": "composites",
            "valueType": "Seq[Int]"
          }
        ],
        "value": "naturals(2).filterNot(composites.contains(_)).take(composites.last - composites.length)"
      },
      {
        "kind": "Dynamic",
        "name": "nPrimes",
        "valueType": "Seq[Int]",
        "parameters": [
          {
            "kind": "Parameter",
            "name": "n",
            "valueType": "Int"
          }
        ],
        "value": "filter(naturals(2)).take(n)"
      }
    ]
  },
  "domainAspect": {
    "typeName": {
      "name": "Primes",
      "namePackage": [
        "draco",
        "primes"
      ]
    },
    "elementTypeNames": [
      "Accumulator",
      "Numbers",
      "AddNaturalSequence.rule",
      "PrimesFromNaturalSequence.rule",
      "RemoveCompositeNumbers.rule"
    ]
  }
}
