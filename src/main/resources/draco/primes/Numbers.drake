type Numbers from Primes
  elements [
    fix primeSequence [Int]
    fix naturalSequence [Int]
    fix compositeSequence [Int]
  ]
  factory Numbers
    parameters [
      par n Int 22
    ]
    body [
      fix primeSequence [Int] Primes.nPrimes(_n)
      fix naturalSequence [Int] Primes.naturals(2).take(primeSequence.last - 1)
      fix compositeSequence [Int] Primes.composites(primeSequence)
    ]
domain draco primes Primes
