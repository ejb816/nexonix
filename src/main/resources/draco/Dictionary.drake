type Dictionary(K, V) from Map(K, V) DracoType
  elements [
    fix kvMap Map(K, V)
    dyn removed Map(K, V)
      parameters
        par key K
      = kvMap.removed(key)
    dyn updated(V1 >: V) Map(K, V1)
      parameters
        par key K
        par value V1
      = kvMap.updated(key, value)
    dyn get Option(V)
      parameters
        par key K
      = kvMap.get(key)
    dyn iterator Iterator((K, V)) kvMap.iterator
  ]
domain draco Draco
