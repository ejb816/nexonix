type Test from Main
  factory
    parameters
      par sourceName String
      par sinkName String
    body
      fix sourceRoot URI classOf[Test].getResource("/").toURI.resolve(java.net.URI.create(s"../../../src/test/${_sourceName}/"))
      fix sinkRoot URI classOf[Test].getResource("/").toURI.resolve(java.net.URI.create(s"../../../src/test/${_sinkName}/"))
  globals
    fix roots Test Test ("resources", "scala")
domain draco Draco
