type ActorAspect
  elements [
    fix start Action
    fix message Action
    fix signal Action
  ]
  factory ActorAspect
    parameters [
      par start Action Action.Null
      par message Action Action.Null
      par signal Action Action.Null
    ]
  globals [
    fix isEmpty (ActorAspect => Boolean) aa =>
      aa.start.body.isEmpty &&
      aa.message.body.isEmpty &&
      aa.signal.body.isEmpty
  ]
domain draco Draco
rule
  pattern
  action
actor
  start
  message
  signal