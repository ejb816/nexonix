<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Clean one-line console pointers ("where the output data is"). -->
  <appender name="STDOUT_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%msg%n</pattern>
    </encoder>
  </appender>

  <!-- Per-suite diagnostic output: routed by the "suite" MDC key (set by
       draco.PersistentTestLog), written to target/test-output/<suite>.log and
       truncated at the start of each run (append=false). Never reaches the console. -->
  <appender name="TEST_OUTPUT" class="ch.qos.logback.classic.sift.SiftingAppender">
    <discriminator>
      <key>suite</key>
      <defaultValue>unattributed</defaultValue>
    </discriminator>
    <sift>
      <appender name="FILE-${suite}" class="ch.qos.logback.core.FileAppender">
        <file>target/test-output/${suite}.log</file>
        <append>false</append>
        <encoder>
          <pattern>%d{HH:mm:ss.SSS} %-5level -- %msg%n</pattern>
        </encoder>
      </appender>
    </sift>
  </appender>

  <logger name="org.apache.pekko" level="WARN"/>

  <!-- Bulky test output: file only, never the console. -->
  <logger name="test.output" level="DEBUG" additivity="false">
    <appender-ref ref="TEST_OUTPUT"/>
  </logger>

  <!-- The per-suite "output is here" pointer: console only, plain. -->
  <logger name="test.report" level="INFO" additivity="false">
    <appender-ref ref="STDOUT_PLAIN"/>
  </logger>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
