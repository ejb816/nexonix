{
  "typeName": {
    "name": "TupleFact",
    "namePackage": ["org", "nexonix", "rules", "rete", "rules"]
  },
  "ruleAspect": {
    "pattern": {
      "kind": "Pattern",
      "variables": [
        {"kind": "Variable", "name": "fact", "valueType": "(Int,Int,Int)"}
      ],
      "conditions": [
        {
          "kind": "Condition",
          "value": "fact._1.equals(1) && fact._2.equals(2) && fact._3.equals(3)",
          "parameters": [
            {"kind": "Parameter", "name": "fact", "valueType": "(Int,Int,Int)"}
          ]
        }
      ]
    },
    "action": {
      "kind": "Action",
      "valueType": "Unit",
      "body": [
        {"kind": "Monadic", "valueType": "Unit", "value": "println(fact)"},
        {"kind": "Monadic", "valueType": "Unit", "value": "println((fact._1, fact._2, fact._3))"}
      ]
    }
  }
}
